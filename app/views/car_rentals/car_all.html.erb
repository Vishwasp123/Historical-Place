<div class="col-lg-12">
  <div class="container">
    <% if @car_rentals.present? %> 
      <h1 class="text-center "><span class="badge bg-primary fs-1">Car Rentals</span></h1>
      <table class="table">
        <thead>
          <tr>
            <th scope="col">Pick_up_location</th>
            <th scope="col">Pick_up_date</th>
            <th scope="col">Pick_up_time</th>
            <th scope="col">Drop_off_location</th>
            <th scope="col">Action</th>

          </tr>
        </thead>
        <tbody>
          <% @car_rentals.each do |car_rental| %>
            <tr>
              <td><%= car_rental.pick_up_location %></td>
              <td><%= car_rental.pick_up_date.strftime("%d %B %Y") %></td>
              <td><%= car_rental.pick_up_time.strftime(" %I:%M%p") %></td>
              <td><%= car_rental.drop_off_location %></td>
              <td><%= link_to 'Show', car_rental_path(car_rental) %></td>
            </tr>
          <% end %>
        </tbody> 
      </table>
      <div class="mt-2">
        <%= paginate @car_rentals %>
      </div>
      <%= link_to "Back", car_rentals_path, class:"btn btn-outline-primary"%>
      <% else %>
      <p class="card-text lead text-danger text-center fs-2"> No Car Rentals Available </p>
    <% end %>
  </div>
</div>